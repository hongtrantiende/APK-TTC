@HiltViewModel
class DisplaySettingsViewModel @Inject constructor(
    val appPrefs: AppPreferences
) : ViewModel()

@OptIn(ExperimentalMaterial3Api
<truncated 8626 bytes>
            .fillMaxWidth()
                        .padding(horizontal = 16.dp, vertical = 8.dp)
                ) {
                    Row(
                        modifier = Modifier.fillMaxWidth(),
                        horizontalArrangement = Arrangement.SpaceBetween
                    ) {
                        Text("Tỷ lệ mật độ", fontSize = 15.sp, color = VBookTheme.textColor())
                        Text("${(densityScale * 100).toInt()}%", fontSize = 14.sp, color = VBookTheme.primaryColor())
                    }
                    Slider(
                        value = densityScale,
                        onValueChange = { densityScale = it },
                        onValueChangeFinished = { prefs.densityScale = densityScale },
                        valueRange = 0.8f..1.5f,
                        steps = 6,
                        colors = SliderDefaults.colors(
                            thumbColor = VBookTheme.primaryColor(),
                            activeTrackColor = VBookTheme.primaryColor(),
                            inactiveTrackColor = VBookTheme.subTextColor().copy(alpha = 0.3f)
                        )
                    )
                }
            }

            Spacer(modifier = Modifier.height(32.dp))
        }
    }

    // Dark mode dialog
    if (showDarkModeDialog) {
        RadioDialog(
            title = "Chế độ tối",
            options = listOf(
                "system" to "Theo hệ thống",
                "light" to "Sáng",
                "dark" to "Tối"
            ),
            selected = darkMode,
            onSelect = { darkMode = it; prefs.darkMode = it },
            onDismiss = { showDarkModeDialog = false }
        )
    }
}
