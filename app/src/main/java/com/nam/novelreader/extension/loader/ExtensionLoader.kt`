    /**
     * Thêm repository mặc định nếu chưa có.
     */
    suspend fun ensureDefaultRepository() {
        val repos = repositoryDao.getEnabledRepositories()
        val hasLocal = repos.any { it.url == "file:///android_asset/plugin.json" }
        val hasOnline = repos.any { it.url == DEFAULT_REPO_URL }

        if (!hasLocal) {
            repositoryDao.insert(
                RepositoryEntity(
                    url = "file:///android_asset/plugin.json",
                    name = "Thư viện Tiện ích (Mặc định)",
                )
            )
        }
        if (!hasOnline) {
            repositoryDao.insert(
                RepositoryEntity(
                    url = DEFAULT_REPO_URL,
                    name = "VBook Community Extensions",
                )
            )
        }

        // Cập nhật các URL repo cũ của vBook nếu có
        repos.firstOrNull { it.url.contains("vbook-f7b28d50") }?.let { oldRepo ->
            repositoryDao.insert(oldRepo.copy(url = DEFAULT_REPO_URL))
        }
    }

    private fun String.toSlug(): String {
        // Normalize Unicode → strip diacritics → lowercase → slug
        val normalized = java.text.Normalizer.normalize(this, java.text.Normalizer.Form.NFD)
            .replace(Regex("[\\p{InCombiningDiacriticalMarks}]"), "")
        return normalized
            .lowercase()
            .replace("đ", "d").replace("Đ", "d")
            .replace(Regex("[^a-z0-9]"), "-")
            .replace(Regex("-+"), "-")
            .trim('-')
    }
